{
  "name": "ai-translate",
  "version": "0.1.0",
  "description": "CLI tool to translate EPUB/FB2 books using Ollama models while preserving formatting",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "ai-translate": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "epub",
    "fb2",
    "translate",
    "ollama",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-xml-parser": "^5.2.5",
    "node-html-parser": "^7.0.1",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}