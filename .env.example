# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://local_user:local_user_dev@localhost:5432/ai_translate

# API base URL (OpenAI-compatible endpoint — Ollama, LM Studio, OpenAI, etc.)
OPENAI_BASE_URL=http://localhost:1234
# (legacy alias: OLLAMA_URL)

# Default model for translation
TRANSLATE_MODEL=hy-mt2-7b
# (legacy alias: OLLAMA_MODEL)

# OCR model for PDF parsing (vision-capable model)
OCR_MODEL=deepseek-ocr

# LLM provider: lmstudio, ollama, remote
# - lmstudio: auto load/unload model via lms CLI
# - ollama: Ollama native (future)
# - remote: no local model management (OpenAI, OpenRouter, etc.)
LLM_PROVIDER=lmstudio

# Upload-only mode: books are parsed and stored but NOT translated
# Useful for testing the upload/parsing pipeline
# UPLOAD_ONLY=true

# API key (optional, required for remote providers like OpenAI)
# OPENAI_API_KEY=***

# Max characters per translation chunk
CHUNK_SIZE=8000

# Web server port (used by "npm run web")
PORT=3000