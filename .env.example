# API base URL (OpenAI-compatible endpoint — Ollama, LM Studio, OpenAI, etc.)
OPENAI_BASE_URL=http://localhost:11434
# (legacy alias: OLLAMA_URL)

# Default model for translation
OLLAMA_MODEL=llama3.1

# API key (optional, required for remote providers like OpenAI)
# OPENAI_API_KEY=sk-***

# Max characters per translation chunk
CHUNK_SIZE=8000

# Web server port (used by "npm run web")
PORT=3000