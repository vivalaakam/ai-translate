# API base URL (OpenAI-compatible endpoint — Ollama, LM Studio, OpenAI, etc.)
OPENAI_BASE_URL=http://localhost:1234
# (legacy alias: OLLAMA_URL)

# Default model for translation
OLLAMA_MODEL=hy-mt2-7b

# LLM provider: lmstudio, ollama, remote
# - lmstudio: auto load/unload model via lms CLI
# - ollama: Ollama native (future)
# - remote: no local model management (OpenAI, OpenRouter, etc.)
LLM_PROVIDER=lmstudio

# API key (optional, required for remote providers like OpenAI)
# OPENAI_API_KEY=*** Max characters per translation chunk
CHUNK_SIZE=8000

# Web server port (used by "npm run web")
PORT=3000